# IDE Settings
.idea/         # IntelliJ IDEA project files
.eclipse/      # Eclipse project files
.vscode/       # VS Code settings
*.iml          # IntelliJ module files
.classpath
.project
.settings/

# Build Artifacts
target/        # Maven build output directory
out/           # IntelliJ build output directory
build/         # Gradle build output directory
*.jar          # Packaged application JAR files
*.war
*.ear

# Dependency Management
.gradle/       # Gradle cache and files
.m2/           # Maven repository cache (usually global, but sometimes found locally)
/lib/
/bin/

# Logging and temporary files
*.log
logs/
tmp/
*.swp
*~

# OS and System Files
.DS_Store      # macOS files
Thumbs.db      # Windows files
Desktop.ini
